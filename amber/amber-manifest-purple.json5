{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/rdi-foundation/mle-bench-purple:v1.0",
    entrypoint: [
      "/opt/conda/envs/purple/bin/python",
      "/home/purple/src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "8080"
    ],
    env: {
      LOG_LEVEL: "INFO"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8080 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
    },
    required: [],
    additionalProperties: false
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  }
}
