{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      kaggle_username: { type: "string", secret: true },
      kaggle_key: { type: "string", secret: true },
    },
    required: ["kaggle_username", "kaggle_key"],
    additionalProperties: false
  },
  components: {
    gateway: {
      manifest: "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/tags/v0.1/amber-manifest.json5",
      config: {
        assessment_config: {
          "competition_id": "spaceship-titanic"
        },
        participant_roles: {
          green: "evaluator",
          purple1: "agent"
        },
        callback_urls: {
          green: "${bindings.green-proxy.url}"
        }
      }
    },
    green: {
      manifest: "./amber-manifest-green.json5",
      config: {
        kaggle_username: "${config.kaggle_username}",
        kaggle_key: "${config.kaggle_key}",
      }
    },
    purple_agent: {
      manifest: "./amber-manifest-purple.json5",
      config: {
      }
    }
  },
  bindings: [
    { to: "#gateway.green", from: "#green.a2a" },
    { to: "#gateway.purple1", from: "#purple_agent.a2a" },
    { to: "#green.proxy", from: "#gateway.proxy", weak: true, name: "green-proxy" }
  ],
  exports: { results: "#gateway.results" }
}
